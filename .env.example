# ==========================================
# .env.example — Unified CI/Local Environment
# ==========================================

# === Versions & Gateway ===
GATEWAY_VERSION=latest
AUTH_VERSION=latest
CRATE_VERSION=latest
ECONOMY_VERSION=latest
RELAY_VERSION=latest
PREVIEW_VERSION=latest
GATEWAY_PORT=80

# === Environment ===
NODE_ENV=test
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
ENVIRONMENT=development

# === Database (PostgreSQL) ===
DB_PASSWORD=ci_test_postgres_password
POSTGRES_DB=crate_digger
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/${POSTGRES_DB}

# === Cache (Redis) ===
REDIS_PASSWORD=ci_test_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# === Object Storage (MinIO / S3) ===
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=test-bucket
S3_ENDPOINT_URL=http://minio:9000
STORAGE_BACKEND=minio
MINIO_ROOT_USER=${S3_ACCESS_KEY}
MINIO_ROOT_PASSWORD=${S3_SECRET_KEY}
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_URL=http://localhost:9000

# === Auth & Economy Services ===
JWT_SECRET_KEY=dev_secret_key_change_in_prod
UNISENDER_API_KEY=your_unisender_api_key_here
UNISENDER_LIST_ID=your_unisender_list_id_here
YOOKASSA_SHOP_ID=your_yookassa_shop_id_here
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here

# === crate-digger ===
DISCOGS_USER_AGENT=CrateDigger/1.0
DISCOGS_TOKEN=your_discogs_token_here
IMAGE_THUMBNAIL_SIZE=300,300
UVICORN_WORKERS=2
CELERY_WORKER_CONCURRENCY=2

# === ytb-audio-relay ===
API_ID=12345678
API_HASH=your_telegram_api_hash_here
PHONE=+1234567890
SESSION_NAME=/app/sessions/ytb_session

# === ytb-audio-preview ===
REDIS_EVENT_CHANNEL=preview:trigger

# === Build-time only ===
NPM_TOKEN=placeholder_for_build