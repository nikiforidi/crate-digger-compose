# ==========================================
# .env.example — Unified CI/Local Environment
# Скопируйте: cp .env.example .env
# Никогда не коммитьте реальные секреты
# ==========================================

# === Versions & Gateway ===
CRATE_VERSION=1.0.3
AUDIO_VERSION=v1.0.3
GATEWAY_PORT=80

# === Environment ===
NODE_ENV=test
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# === Database (PostgreSQL) ===
DB_PASSWORD=ci_test_pass
POSTGRES_DB=crate_digger
# Полные URL для pydantic/SQLAlchemy валидации
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/${POSTGRES_DB}

# === Cache (Redis) ===
REDIS_PASSWORD=ci_test_pass
# crate-digger (Python) требует пароль в URL
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# audio-processor (Node.js) может работать без пароля в тесте
# REDIS_URL=redis://redis:6379

# === Object Storage (MinIO / S3) ===
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=test-bucket
S3_ENDPOINT_URL=http://minio:9000
STORAGE_BACKEND=minio

# MinIO требует отдельные переменные (значения = S3 ключам)
MINIO_ROOT_USER=${S3_ACCESS_KEY}
MINIO_ROOT_PASSWORD=${S3_SECRET_KEY}
MINIO_ENDPOINT=minio:9000

# === crate-digger (Python/FastAPI) ===
DISCOGS_TOKEN=          # ← задаётся в CI: ${{ secrets.DISCOGS_TOKEN }}
DISCOGS_USER_AGENT=CrateDigger/1.0
IMAGE_THUMBNAIL_SIZE=300,300
UVICORN_WORKERS=2       # уменьшено для CI
CELERY_WORKER_CONCURRENCY=2

# === audio-processor (Node.js/TS) ===
PORT=3000
MINIO_BUCKET=audio-assets-prod
CRATE_DIGGER_BASE_URL=http://crate-digger:8000  # internal network в CI
YTDLP_TIMEOUT=180000
YTDLP_FORMAT=m4a/bestaudio

# === Build-time only (не используется в runtime CI) ===
NPM_TOKEN=placeholder_for_build