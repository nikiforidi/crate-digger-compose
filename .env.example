# ==========================================
# .env.example — Unified CI/Local Environment
# Скопируйте: cp .env.example .env
# Никогда не коммитьте реальные секреты (.env)
# ==========================================

# === Versions & Gateway ===
GATEWAY_VERSION=latest
AUTH_VERSION=latest
CRATE_VERSION=latest
ECONOMY_VERSION=latest
RELAY_VERSION=latest
PREVIEW_VERSION=latest
GATEWAY_PORT=80

# === Environment ===
NODE_ENV=test
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# === Database (PostgreSQL) ===
DB_PASSWORD=ci_test_pass
POSTGRES_DB=crate_digger
# Полный URL для pydantic/SQLAlchemy валидации
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@db:5432/${POSTGRES_DB}

# Auth Service Database (создаётся автоматически через db-init контейнер)
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/auth_db

# Economy Service Database (создаётся автоматически через db-init контейнер)
ECONOMY_DATABASE_URL=postgresql+asyncpg://postgres:${DB_PASSWORD}@db:5432/economy_db

# === Cache (Redis) ===
REDIS_PASSWORD=ci_test_pass
# Python-сервисы требуют пароль в URL
# Используем разные DB для изоляции данных сервисов
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_URL_AUTH=redis://:${REDIS_PASSWORD}@redis:6379/1
REDIS_URL_ECONOMY=redis://:${REDIS_PASSWORD}@redis:6379/2

# === Object Storage (MinIO / S3) ===
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=test-bucket
S3_ENDPOINT_URL=http://minio:9000
STORAGE_BACKEND=minio
# MinIO требует отдельные переменные (значения = S3 ключам)
MINIO_ROOT_USER=${S3_ACCESS_KEY}
MINIO_ROOT_PASSWORD=${S3_SECRET_KEY}
MINIO_ENDPOINT=minio:9000
# Публичный URL для генерации ссылок в API ответах (браузерный доступ)
MINIO_PUBLIC_URL=http://localhost:9000

# === auth-service (Python/FastAPI) ===
JWT_SECRET_KEY=super_secret_dev_key_change_in_prod
UNISENDER_API_KEY=your_unisender_api_key_here
UNISENDER_LIST_ID=your_unisender_list_id_here
FRONTEND_URL=http://localhost:3000
EMAIL_BACKEND=unisender

# === economy-service (Python/FastAPI) ===
PLATFORM_FEE_PERCENTAGE=0.10
YOOKASSA_SHOP_ID=your_yookassa_shop_id_here
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here
YOOKASSA_RETURN_URL=http://localhost:3000/checkout/result
YOOKASSA_TEST_MODE=true
CATALOG_SERVICE_URL=http://crate-digger:8000
AUTH_SERVICE_URL=http://auth-service:8000

# === crate-digger (Python/FastAPI) ===
DISCOGS_USER_AGENT=CrateDigger/1.0
DISCOGS_TOKEN=your_discogs_token_here
IMAGE_THUMBNAIL_SIZE=300,300
UVICORN_WORKERS=2
CELERY_WORKER_CONCURRENCY=2

# === ytb-audio-relay (Python/FastAPI + ARQ) ===
# Замените на реальные данные вашего Telegram-аккаунта/бота
API_ID=12345678
API_HASH=your_telegram_api_hash_here
PHONE=+1234567890
# Путь внутри контейнера для сохранения сессии Telegram
SESSION_NAME=/app/sessions/ytb_session

# === ytb-audio-preview (Python/FastAPI + ARQ) ===
REDIS_EVENT_CHANNEL=preview:trigger

# === Build-time only (не используется в runtime CI) ===
NPM_TOKEN=placeholder_for_build

# === API Gateway ===
GATEWAY_VERSION=latest
ENVIRONMENT=production  # development | production
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# Circuit breaker
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60

# Cache TTL (seconds)
CACHE_TTL_RELEASES=3600
CACHE_TTL_SELLERS=60
CACHE_TTL_USERS=300