# ==========================================
# .env.testing — Базовые значения для CI/тестов
# Секреты переопределяются в test-compose.yml через env блок
# ==========================================

# === Versions ===
GATEWAY_VERSION=latest
AUTH_VERSION=latest
CRATE_VERSION=latest
MARKETPLACE_VERSION=latest
ECONOMY_VERSION=latest
RELAY_VERSION=latest
PREVIEW_VERSION=latest

# === Gateway ===
GATEWAY_PORT=80

# === Environment ===
NODE_ENV=test
ENVIRONMENT=testing
LOG_LEVEL=INFO

# === Database ===
DB_PASSWORD=ci_test_password
POSTGRES_DB=crate_digger

# === Redis ===
REDIS_PASSWORD=ci_test_password

# === MinIO/S3 ===
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=test-bucket
S3_ENDPOINT_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000

# === Auth Service (секреты переопределяются в test-compose.yml) ===
JWT_SECRET_KEY=ci_test_jwt_secret_key
UNISENDER_API_KEY=ci_test_unisender_api_key
UNISENDER_LIST_ID=ci_test_unisender_list_id
FRONTEND_URL=http://localhost:3000
EMAIL_BACKEND=unisender

# === Economy Service (секреты переопределяются в test-compose.yml) ===
PLATFORM_FEE_PERCENTAGE=0.10
YOOKASSA_SHOP_ID=ci_test_yookassa_shop_id
YOOKASSA_SECRET_KEY=ci_test_yookassa_secret_key
YOOKASSA_RETURN_URL=http://localhost:3000/checkout/result
YOOKASSA_TEST_MODE=true
CATALOG_SERVICE_URL=http://crate-digger:8000
AUTH_SERVICE_URL=http://auth-service:8000

# === Crate Digger (секреты переопределяются в test-compose.yml) ===
DISCOGS_TOKEN=ci_test_discogs_token

# === Gateway Settings ===
HTTP_TIMEOUT=30.0
RATE_LIMIT_DEFAULT=1000/minute
RATE_LIMIT_AUTH=100/minute
CIRCUIT_BREAKER_FAIL_MAX=5
CIRCUIT_BREAKER_RESET_TIMEOUT=60
CACHE_TTL_RELEASES=3600
CACHE_TTL_SELLERS=60
CACHE_TTL_USERS=300

# === Telegram (секреты переопределяются в test-compose.yml) ===
API_ID=12345678
API_HASH=ci_test_api_hash
PHONE=+1234567890
SESSION_NAME=/app/sessions/ytb_session

# === Preview Service ===
REDIS_EVENT_CHANNEL=preview:trigger

# === ФАЗА 1: Auth ===
INITIAL_ADMIN_EMAIL=admin@crate.market

# === ФАЗА 2 + 3 + 4: Внутренний токен между сервисами ===
INTERNAL_SERVICE_TOKEN=change_me_to_random_string_in_production

GHCR_USERNAME=ваш_github_login
GHCR_PASSWORD=ghp_ваш_токен