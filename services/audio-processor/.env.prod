# App
PORT=3000
NODE_ENV=production

# Services (use external Redis/MinIO in real prod)
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=audio-assets-prod

# External
CRATE_DIGGER_BASE_URL=https://api.crate-digger.example.com

# yt-dlp
YTDLP_TIMEOUT=180000
YTDLP_FORMAT=m4a/bestaudio

# Security
# NPM_TOKEN injected via CI build-arg, NOT in this file